# exp 20 회고: 디자인/문구 변경이 e2e 셀렉터를 깼는데 push 시점에 아무 gate 도 없어
# CI 에 가서야 실패가 드러났다. pr:gate 는 가볍게 유지하고, 대신 push 직전에만
# Playwright E2E 를 돌려 "계층 간 파손" 을 로컬에서 먼저 잡는다.
#
# 긴급 시 우회: git push --no-verify
# e2e 스킵 시:  LAB_SKIP_E2E=1 git push
if [ -n "$LAB_SKIP_E2E" ]; then
  echo "[pre-push] LAB_SKIP_E2E=1 — e2e 스킵"
  exit 0
fi

# Next 15 는 한 프로젝트 디렉토리에서 dev 를 두 번 기동하지 못한다.
# 사용자가 이미 `npm run dev` 로 3000 을 쓰고 있으면, playwright 에게 그 서버를
# reuse 하도록 PORT 를 맞춰준다. (그렇지 않으면 webServer 가 3100 을 띄우려다
# "Another next dev server is already running" 으로 실패한다)
if lsof -ti:3000 >/dev/null 2>&1; then
  echo "[pre-push] 기존 dev 서버(3000) 감지 — reuse 모드로 e2e"
  PORT=3000 npm run e2e
else
  echo "[pre-push] Playwright E2E 실행 (dev 서버 부팅 포함, 약 30~60초)"
  npm run e2e
fi

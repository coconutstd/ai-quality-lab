{
  "name": "ai-quality-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ENABLE_TEST_RESET=true MOCK_AUTH=true next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "audit:components": "node .claude/hooks/audit-components.mjs --strict",
    "sync:rules": "node .claude/scripts/sync-rules.mjs",
    "check:rules": "node .claude/scripts/sync-rules.mjs --check",
    "test:guard": "node .claude/hooks/test-guard.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "pr:gate": "npm run lint && npm run typecheck && npm run test:run && npm run audit:components && npm run check:rules && npm run test:guard",
    "ci:e2e": "playwright test",
    "pr:review": "coderabbit review --agent -t all",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "axios": "^1.15.2",
    "dompurify": "^3.4.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.73.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "storybook": "^9.1.20",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
